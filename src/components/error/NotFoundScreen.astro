---
import PreBlock from "../textmode/PreBlock.astro";
import { link, textHtml } from "../../modules/textmode/core/html";

const lines = [
  "0000000000401400 <_route_lookup>:",
  "  401400: 48 8b 04 25 04 04 00 00  mov    rax, QWORD PTR ds:0x404",
  "  401408: 0f 0b                    ud2",
  "  40140a: cc                       int3",
  "",
  "──[ SIGSEGV ]───────────────────────────────────────────────────────────────────",
  "",
  "  fault addr : 0x0000000000000404",
  "  mapping    : not present",
  "  access     : read",
  "  reason     : phile not linked into this page",
  "",
  "  ┌───────────────────────────────────────────────────────────────────────────┐",
  "  │ The requested route fell through the archive and hit unmapped text.       │",
  "  └───────────────────────────────────────────────────────────────────────────┘",
  ""
];

const html = `${textHtml(lines.join("\n"))}\njmp ${link("/", "<_start>")}\n`;
---

<section class="home-shell notfound-shell">
  <PreBlock class="home-pre notfound-pre" html={html} />
</section>
