---
import PreBlock from "../textmode/PreBlock.astro";
import { siteConfig, type HomeItem, type HomeSection } from "../../config";
import type { Volume } from "../../modules/volumes/model";
import { escapeHtml, externalLink, link, textHtml } from "../../modules/textmode/core/html";
import { cellWidth, wrapWordsCells } from "../../modules/textmode/core/layout";
import { volumeListLabel } from "../../modules/volumes/labels";

type Props = {
  volumes: Volume[];
};

const volumes = Astro.props.volumes;
const asciiText = siteConfig.homeAsciiArt;
const homeLineWidth = Math.max(...asciiText.split("\n").map(cellWidth));
const homeLines = siteConfig.homeSections.flatMap((section) => renderHomeSection(section, volumes));
const homeText = `${homeLines.join("\n")}\n`;
const asciiHtml = textHtml(asciiText);
const asciiAttr = escapeHtml(asciiText);

function renderHomeSection(section: HomeSection, allVolumes: Volume[]): string[] {
  const items = renderHomeItems(section, allVolumes);

  if (items.length === 0 && section.volumes?.showEmpty === false) {
    return [];
  }

  return ["", `~ ${section.title}`, ...items];
}

function renderHomeItems(section: HomeSection, allVolumes: Volume[]): string[] {
  return [
    ...renderVolumeItems(section, allVolumes),
    ...(section.items ?? []).flatMap(renderHomeItem)
  ];
}

function renderVolumeItems(section: HomeSection, allVolumes: Volume[]): string[] {
  if (!section.volumes) {
    return [];
  }

  const included = new Set(section.volumes.include);
  const excluded = new Set(section.volumes.exclude);
  const filtered = allVolumes
    .filter((volume) => included.size === 0 || included.has(volume.number))
    .filter((volume) => !excluded.has(volume.number))
    .sort((left, right) =>
      section.volumes?.sort === "desc"
        ? right.number - left.number
        : left.number - right.number
    );

  return filtered.flatMap((volume) =>
    renderHomeItem({
      label: volumeListLabel(volume),
      href: volume.href
    })
  );
}

function renderHomeItem(item: HomeItem): string[] {
  const prefix = `  ${item.prefix ?? "~"} `;
  const labelWidth = Math.max(1, homeLineWidth - cellWidth(prefix));
  const labelLines = wrapWordsCells(item.label, labelWidth);

  return labelLines.map((labelLine, index) => {
    const linePrefix = index === 0 ? prefix : " ".repeat(cellWidth(prefix));
    return `${linePrefix}${renderLabel(item, labelLine)}`;
  });
}

function renderLabel(item: HomeItem, label: string): string {
  if (!item.href) {
    return textHtml(label);
  }

  if (item.linkLabel) {
    const linkIndex = label.indexOf(item.linkLabel);

    if (linkIndex !== -1) {
      const before = label.slice(0, linkIndex);
      const linked = label.slice(linkIndex, linkIndex + item.linkLabel.length);
      const after = label.slice(linkIndex + item.linkLabel.length);
      const linkedHtml = item.external
        ? externalLink(item.href, linked)
        : link(item.href, linked);

      return `${textHtml(before)}${linkedHtml}${textHtml(after)}`;
    }
  }

  return item.external ? externalLink(item.href, label) : link(item.href, label);
}
---

<section class="home-shell">
  <div class="ascii-hero">
    <pre
      id="home-ascii"
      class="textmode-pre home-pre ascii-pre"
      data-ascii-text={asciiAttr}
      set:html={asciiHtml}
    ></pre>
    <pre
      id="home-ascii-glitch"
      class="textmode-pre home-pre ascii-pre ascii-glitch"
      aria-hidden="true"
    ></pre>
  </div>
  <PreBlock class="home-pre" html={homeText} />
</section>

<script>
  import { initHomeAsciiGlitch } from "../../modules/textmode/glitch/home";

  window.addEventListener(
    "load",
    () => {
      window.setTimeout(initHomeAsciiGlitch, 1200);
    },
    { once: true, passive: true }
  );
</script>
